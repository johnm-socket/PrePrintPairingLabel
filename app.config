<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!--
      Label type definitions. Add more by incrementing the index (0, 1, 2...).
      TemplatePath: full path to the BarTender .btw file.
      BarcodeField: name of the SubString variable in the template that holds the barcode data.
    -->
    <add key="LabelType.0.Name"          value="Magic Dock" />
    <add key="LabelType.0.TemplatePath"  value="MagicDock.btw" />
    <add key="LabelType.0.BarcodeField"  value="Barcode 1" />

    <add key="LabelType.1.Name"          value="SM-Link" />
    <add key="LabelType.1.TemplatePath"  value="SMLink.btw" />
    <add key="LabelType.1.BarcodeField"  value="Barcode 1" />
  </appSettings>
</configuration>
